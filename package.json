{
  "name": "ticko-backend",
  "version": "1.0.0",
  "description": "Scalable event ticketing backend (Eventbrite-like) with Node, Express, PostgreSQL, Prisma, Redis, Stripe, and BullMQ.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "test": "jest --runInBand",
    "lint": "echo \"no linter configured\"",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "node prisma/seed.js",
    "worker": "node src/jobs/workers.js"
  },
  "keywords": [
    "express",
    "prisma",
    "postgresql",
    "redis",
    "stripe",
    "bullmq",
    "event-ticketing"
  ],
  "author": "Lucas",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.0.0",
    "compression": "^1.7.4",
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pdfkit": "^0.14.0",
    "qrcode": "^1.5.3",
    "stripe": "^16.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "winston": "^3.10.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "prisma": "^6.0.0",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/src/tests/**/*.test.js"
    ]
  }
}
